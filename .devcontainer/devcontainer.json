{
  "name": "antel",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",

  // Claude Code CLI inside the container.
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },

  // Rootless Podman: map the host UID onto the container user so bind mounts
  // (the ~/.claude login + the podman socket) are owned correctly.
  "runArgs": ["--userns=keep-id"],

  "mounts": [
    // Reuse the host's Claude Code login (credentials in ~/.claude/.credentials.json) —
    // bind the *directory* (not the single ~/.claude.json) to avoid atomic-write failures.
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",

    // Talk to the HOST's rootless Podman (podman-outside-of-podman): Molecule target
    // containers and the Jaeger viewer run as *siblings* on the host engine.
    // Enable the host socket first:  systemctl --user enable --now podman.socket
    // If $XDG_RUNTIME_DIR is unset on your host, hardcode /run/user/<uid>/podman/podman.sock.
    "source=${localEnv:XDG_RUNTIME_DIR}/podman/podman.sock,target=/run/podman/podman.sock,type=bind"
  ],

  "containerEnv": {
    "CONTAINER_HOST": "unix:///run/podman/podman.sock",
    "DOCKER_HOST": "unix:///run/podman/podman.sock"
  },

  "remoteEnv": {
    "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}"
  },

  // Install the podman client (used as a remote client against the host socket) + uv,
  // then sync the pinned toolchain and Ansible collections.
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y podman && curl -LsSf https://astral.sh/uv/install.sh | sh && uv sync && uv run ansible-galaxy collection install -r collections/requirements.yml",

  "remoteUser": "vscode"
}
