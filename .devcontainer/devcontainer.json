{
  "name": "antel",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",

  // docker-in-docker gives Molecule a container engine *inside* the devcontainer to
  // spin throwaway target containers and run the Jaeger viewer. Requires a privileged
  // container (the feature configures it; some Podman hosts also need runArgs below).
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    // Installs the Claude Code CLI inside the container.
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {}
  },

  // Reuse the host's Claude Code login: bind-mount the ~/.claude *directory*
  // (credentials live in ~/.claude/.credentials.json). Mounting the directory — not
  // the single ~/.claude.json file — avoids atomic-write/rename failures.
  // The container then shares your real credentials and refreshes tokens back to the host.
  // Cleaner-but-requires-one-login alternative:
  //   "source=claude-code-config,target=/home/vscode/.claude,type=volume"
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
  ],

  // Uncomment if nested docker fails to start under your Podman host:
  // "runArgs": ["--privileged"],

  // uv lives in the container only; install it, then sync the pinned toolchain + collections.
  "remoteEnv": {
    "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && uv sync && uv run ansible-galaxy collection install -r collections/requirements.yml",

  "forwardPorts": [16686],
  "portsAttributes": {
    "16686": { "label": "Jaeger UI" }
  },

  "remoteUser": "vscode"
}
