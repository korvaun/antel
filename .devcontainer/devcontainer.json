{
  "name": "antel",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",

  // docker-in-docker gives Molecule a container engine *inside* the devcontainer to
  // spin throwaway target containers and run the Jaeger viewer. Requires a privileged
  // container (the feature configures it; some Podman hosts also need runArgs below).
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // Uncomment if nested docker fails to start under your Podman host:
  // "runArgs": ["--privileged"],

  // uv lives in the container only; install it, then sync the pinned toolchain + collections.
  "remoteEnv": {
    "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && uv sync && uv run ansible-galaxy collection install -r collections/requirements.yml",

  "forwardPorts": [16686],
  "portsAttributes": {
    "16686": { "label": "Jaeger UI" }
  },

  "remoteUser": "vscode"
}
